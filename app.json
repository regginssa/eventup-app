{
  "expo": {
    "name": "Charlie Party",
    "slug": "charlie-party",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "charlieparty",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.charlieunicornai.charlieparty",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyBZhXrql_BqZA9QbARhs9wpEM2whstsIMc"
      },
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Charlie Party needs access to your location to show nearby events.",
        "NSPhotoLibraryUsageDescription": "Charlie Party requires access to your photo library to let you upload pictures for events.",
        "NSCameraUsageDescription": "Charlie Party uses the camera to let you take photos for your events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.charlieunicornai.charlieparty",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBZhXrql_BqZA9QbARhs9wpEM2whstsIMc"
        }
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Charlie Party accesses your photos to let you share them with your friends."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b321bfc9-d1b6-4e5e-b248-e0a04375f251"
      }
    },
    "owner": "charlie-unicorn-ai"
  }
}
