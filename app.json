{
  "expo": {
    "name": "EventUp",
    "slug": "eventup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eventup",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.charlieunicornai.eventup",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyD-ctseOmsg3Gg2fTwPyN6XmY_kgMOpVrI"
      },
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "EventUp needs access to your location to show nearby events.",
        "NSPhotoLibraryUsageDescription": "EventUp requires access to your photo library to let you upload pictures for events.",
        "NSCameraUsageDescription": "EventUp uses the camera to let you take photos for your events.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.charlieunicornai.eventup",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD-ctseOmsg3Gg2fTwPyN6XmY_kgMOpVrI"
        }
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EventUp accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-localization",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43130ed1-f67b-4ed3-8442-df4cfa60aab8"
      }
    },
    "owner": "charlie-unicorn-ai"
  }
}
